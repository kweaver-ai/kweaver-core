{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "写入 Dataset 文档",
    "description": "向指定 Dataset 写入文档数据",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
        },
        "title": {
            "type": "string"
        },
        "operator": {
            "type": "string",
            "pattern": "^@dataset/write-docs$",
            "maxLength": 255
        },
        "parameters": {
            "type": "object",
            "properties": {
                "dataset_id": {
                    "type": "string",
                    "description": "目标 Dataset ID",
                    "minLength": 1
                },
                "documents": {
                    "description": "要写入的文档数据，支持单个对象、对象数组或 JSON 字符串",
                    "oneOf": [
                        {
                            "type": "object",
                            "description": "单个文档对象"
                        },
                        {
                            "type": "array",
                            "description": "文档对象数组",
                            "items": {
                                "type": "object"
                            }
                        },
                        {
                            "type": "string",
                            "description": "JSON 格式的文档数据字符串"
                        }
                    ]
                },
                "output_var": {
                    "type": "string",
                    "description": "输出变量名，用于存储操作结果",
                    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
                }
            },
            "additionalProperties": false,
            "required": [
                "dataset_id",
                "documents"
            ]
        },
        "settings": {
            "$ref": "../common.json#/definitions/Settings"
        }
    },
    "required": [
        "id",
        "operator",
        "parameters"
    ],
    "additionalProperties": false
}
