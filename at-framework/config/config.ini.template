; =============================================================================
; 配置模板：复制为 config.ini 后按环境填写（不要将含密钥的 config.ini 提交到仓库）
; 框架读取：conftest / common.at_env / src.config.setting
; =============================================================================

[server]
; HTTP 客户端超时（秒）
timeout = 10
; 被测 API 主机（可被环境变量 AT_SERVER_HOST / SERVER_HOST 覆盖）
host = <YOUR_API_HOST>
; 与 host 同环境的完整基址，用于推导请求协议 https|http（见 common.at_env.request_scheme）
base_url = https://<YOUR_API_HOST>
; 登录流程端口（src/auth/login.py）
public_port = 443
ssh_port = 22
ssh_user = <SSH_USER>
ssh_password = <SSH_PASSWORD>

[database]
host = <DB_HOST>
port = <DB_PORT>
user = <DB_USER>
password = <DB_PASSWORD>
database = <DB_NAME>

[view_data]
host = <VIEW_DB_HOST>
port = 3306
user = <VIEW_DB_USER>
password = <VIEW_DB_PASSWORD>
database = <VIEW_DB_NAME>

[embedding_info]
embedding_model_name = <EMBEDDING_MODEL_NAME>
embedding_model_type = embedding
embedding_api_url = <EMBEDDING_API_URL>
embedding_api_model = <EMBEDDING_API_MODEL>
embedding_api_key = <EMBEDDING_API_KEY>

[llm_info]
llm_name = <LLM_NAME>
llm_series = deepseek
llm_max_model_len = 128
llm_api_model = <LLM_API_MODEL>
llm_api_url = <LLM_API_URL>
llm_api_key = <LLM_API_KEY>

[rerank_info]
rerank_model_name = <RERANK_MODEL_NAME>
rerank_model_type = reranker
rerank_api_url = <RERANK_API_URL>
rerank_api_model = <RERANK_API_MODEL>
; 与 small-model/add 中 batch_size 一致，默认 2048
rerank_batch_size = 2048

[oss_info]
storage_name = <STORAGE_NAME>
vendor_type = OBS
endpoint = <OSS_ENDPOINT>
bucket_name = <BUCKET_NAME>
access_key_id = <ACCESS_KEY_ID>
access_key_secret = <ACCESS_KEY_SECRET>
is_default = true
internal_endpoint =
region = <REGION>

[log]
level = INFO
format = %(asctime)s - %(name)s - %(levelname)s - %(message)s

[report]
title = API自动化测试报告
description = 接口自动化测试报告
environment = 测试环境
