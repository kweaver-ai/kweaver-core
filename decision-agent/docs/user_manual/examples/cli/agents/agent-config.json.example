{
  "input": {
    "fields": [
      {
        "name": "query",
        "type": "string"
      }
    ]
  },
  "output": {
    "default_format": "markdown",
    "variables": {
      "answer_var": "answer"
    }
  },
  "llms": [
    {
      "is_default": true,
      "llm_config": {
        "id": "xxx",
        "name": "deepseek-v3",
        "model_type": "llm",
        "temperature": 1,
        "top_p": 1,
        "top_k": 1,
        "frequency_penalty": 0,
        "presence_penalty": 0,
        "max_tokens": 1000,
        "retrieval_max_tokens": 32
      }
    }
  ],
  "memory": {
    "is_enabled": false
  },
  "related_question": {
    "is_enabled": false
  },
  "plan_mode": {
    "is_enabled": false
  }
}
