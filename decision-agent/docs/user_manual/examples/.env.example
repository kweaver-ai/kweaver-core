# 首次使用时可复制为 .env，并按本地环境修改。

KWEAVER_BASE_URL=http://127.0.0.1:13020  # kweaver 服务的基础 URL 地址
KWEAVER_NO_AUTH=1  # 是否跳过认证，1 表示跳过认证
KWEAVER_TOKEN=  # 认证令牌，当需要认证时设置
KWEAVER_BUSINESS_DOMAIN=bd_public  # 业务域名标识

# 命令行工具 / TypeScript SDK 包来源。remote 使用远程 npm 包，local 使用本地 SDK 项目。
KWEAVER_SDK_PACKAGE_SOURCE=remote  # SDK 包来源，可选值：remote 或 local
KWEAVER_SDK_REMOTE_PACKAGE=@kweaver-ai/kweaver-sdk  # 远程 npm 包名
KWEAVER_SDK_TS_DIR=../../../../../kweaver-sdk/packages/typescript  # TypeScript SDK 目录路径

# 创建与完整流程示例使用的模型。不同环境可按需修改。
KWEAVER_LLM_ID=xxx  # LLM 模型 ID
KWEAVER_LLM_NAME=deepseek-v3  # LLM 模型名称

# 运行态状态可以手工设置，也可以由 create 示例写入 .tmp/state.env。
AGENT_ID=  # Agent 的唯一标识符
AGENT_KEY=  # Agent 的访问密钥
AGENT_VERSION=  # Agent 的版本号
CONVERSATION_ID=  # 对话的唯一标识符
AGENT_RUN_ID=  # Agent 运行的唯一标识符
INTERRUPTED_ASSISTANT_MESSAGE_ID=  # 被中断的助手消息 ID

# 可选外部资源。依赖这些值的示例在未设置时会给出明确错误。
KN_ID=  # 知识网络的唯一标识符
SKILL_ID=  # 技能的唯一标识符
TEMPLATE_ID=  # 模板的唯一标识符

# 可选请求内容。
CHAT_MESSAGE=请用一句话介绍你自己  # 聊天消息内容
CONVERSATION_TITLE=示例对话标题  # 对话标题
LIMIT=1  # 查询结果数量限制
