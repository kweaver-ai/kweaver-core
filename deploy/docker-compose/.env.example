# Copy to .env and run ./setup.sh — it renders configs/kweaver/**/*.tmpl into
# configs/generated/ (per-service files + *.env) and validates Compose.

# Compose project (optional)
COMPOSE_PROJECT_NAME=kweaver-compose

# Access (used in migrator config + docs)
ACCESS_HOST=localhost
ACCESS_PORT=8080

# Registry — do NOT append DIP_NAMESPACE here (compose uses ${IMAGE_REGISTRY}/${DIP_NAMESPACE}/...)
IMAGE_REGISTRY=swr.cn-east-3.myhuaweicloud.com/kweaver-ai
DIP_NAMESPACE=dip

# All *_VERSION values are sourced from compose-manifest.yaml (tagEnv).
# setup.sh writes them into .env on every run so this file does not need
# to mirror the manifest. To inspect or change a version, edit
# compose-manifest.yaml; to override a single tag locally without touching
# the manifest, add the corresponding KEY=VAL line below before running
# setup.sh and it will be preserved.

# Infra hostnames inside the compose network (override only if you rename services)
MARIADB_HOST=mariadb
MARIADB_PORT=3306
KAFKA_HOST=kafka
KAFKA_PORT=9092
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
REDIS_HOST=redis

# mdl-data-model AES_KEY (must match existing deployments if you reuse data)
MDL_DATA_MODEL_AES_KEY=46EBA22EF5204DD5B110A1F730513965

# Required secrets — MUST be set before `docker compose up` will work.
# Leaving them empty (the default) makes `docker compose up` refuse to start.
# Easiest: ./setup.sh -p YOUR_PASSWORD

MARIADB_ROOT_PASSWORD=
MARIADB_USER=adp
MARIADB_PASSWORD=
MARIADB_DATABASE=adp

REDIS_USER=default
REDIS_PASSWORD=

KAFKA_USER=kafkauser
KAFKA_PASSWORD=

# Optional dependencies the kweaver-core manifest expects in K8s but are not
# part of the Compose stack (mongo, SASL on Kafka). Leave empty unless you
# wire them up externally.
MONGODB_PASSWORD=
MQ_AUTH_MECHANISM=

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

OPENSEARCH_PASSWORD=

KWEAVER_HTTP_PORT=8080

# Optional override; setup.sh defaults this from MariaDB credentials + MARIADB_HOST/PORT
# if unset (sandbox control plane DATABASE_URL).
SANDBOX_DATABASE_URL=

# Sandbox (control plane publishes SANDBOX_HTTP_PORT -> container 8000)
SANDBOX_HTTP_PORT=8001

AGENT_OBSERVABILITY_TRACE_INDEX=ss4o_traces-default-anyshare

# Namespace label passed to flow-stream-data-pipeline ( Helm .Values.namespace )
SDP_PIPELINE_NAMESPACE=dip

TZ=Asia/Shanghai
