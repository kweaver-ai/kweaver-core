# Copy to .env and adjust. scripts/setup.sh generates configs/generated/config.yaml from Config template.

# Compose project (optional)
COMPOSE_PROJECT_NAME=kweaver-compose

# Paths
KWEAVER_CONFIG_FILE=./configs/generated/config.yaml

# Access (used in generated global config + COMPOSE.md)
ACCESS_HOST=localhost
ACCESS_PORT=8080

# Registry / versions
IMAGE_REGISTRY=swr.cn-east-3.myhuaweicloud.com/kweaver-ai
KWEAVER_VERSION=0.7.0

# Per-chart overrides (non-KWEAVER_VERSION)
DATA_CONNECTION_VERSION=0.6.0
VEGA_GATEWAY_VERSION=0.6.0
VEGA_GATEWAY_PRO_VERSION=0.6.0
MDL_DATA_MODEL_VERSION=0.6.0
MDL_UNIQUERY_VERSION=0.6.0
MDL_DATA_MODEL_JOB_VERSION=0.6.0
SANDBOX_VERSION=0.3.3
OTELCOL_CONTRIB_VERSION=0.2.3
AGENT_OBSERVABILITY_VERSION=0.2.3

# Required secrets — MUST be set before `docker compose up` will work.
# Leaving them empty (the default) makes `docker compose up` and `docker
# compose config` refuse to start with a clear error from interpolation.
# Easiest way to fill all three at once:   ./setup.sh -p YOUR_PASSWORD
# Per-field flags:  --mariadb-root-password / --mariadb-password / --minio-root-password

# MariaDB
MARIADB_ROOT_PASSWORD=
MARIADB_USER=adp
MARIADB_PASSWORD=
MARIADB_DATABASE=adp

# Redis (compose runs Redis without requirepass on the internal network;
# this value is kept for future use and is NOT consumed today)
REDIS_PASSWORD=

# Kafka (compose uses Confluent PLAINTEXT — these credentials are NOT enforced
# at runtime; they are only written into the generated config.yaml in case
# the broker is later switched to SASL/SCRAM)
KAFKA_USER=kafkauser
KAFKA_PASSWORD=

# MinIO (sandbox)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# OpenSearch (DISABLE_SECURITY_PLUGIN=true in compose — no auth)
OPENSEARCH_PASSWORD=

# Sandbox control plane (Python DSN). setup.sh OVERWRITES this line so its
# password matches MARIADB_USER + MARIADB_PASSWORD; do not edit by hand.
SANDBOX_DATABASE_URL=

# Sandbox host port (avoid clashing with KWEAVER_HTTP_PORT)
SANDBOX_HTTP_PORT=8001

# Host port for nginx entry
KWEAVER_HTTP_PORT=8080

TZ=Asia/Shanghai
