    port: 8098
    protocol: http
  data-manager:
    host: data-manager-svc
    port: 13013
    protocol: http
  data-model:
    host: mdl-data-model
    port: 13020
    protocol: http
  hydra-admin:
    host: nginx
    port: 4445
    protocol: http
  index-base:
    host: mdl-index-base-svc
    port: 13013
    protocol: http
  mq:
    auth:
      mechanism: ""
      password: testpwd
      username: test
    mqHost: __KAFKA_HOST__
    mqPort: __KAFKA_PORT__
