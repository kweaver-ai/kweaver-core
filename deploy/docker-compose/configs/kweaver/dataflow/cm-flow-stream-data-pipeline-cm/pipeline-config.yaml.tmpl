server:
  cpuMax: 8
  failureThreshold: 10
  flushIntervalSec: 3
  flushItems: 10000
  flushMiB: 5
  httpPort: 13012
  language: zh-CN
  maxPipelineCount: 100
  memoryMax: 8192
  monitorIntervalSec: 10
  packagePoolSize: 40
  readTimeOut: 120
  retryIntervalMs: 3000
  runMode: release
  watchDeployInterval: 10
  watchWorkersIntervalMin: 5
  writeTimeOut: 120
log:
  developMode: false
  logLevel: info
  maxAge: 100
  maxBackups: 20
  maxSize: 100
kafka:
  adminClientOperationTimeoutMs: 60000
  adminClientRequestTimeoutMs: 30000
  autoOffsetReset: earliest
  heartbeatIntervalMs: 10000
  maxPollIntervalMs: 300000
  retentionSize: -1
  retentionTime: 7d
  retries: 5
  retryBackoffMs: 500
  sessionTimeoutMs: 45000
  socketTimeoutMs: 60000
  transactionTimeoutMs: 60000
depServices:
  authorization-private:
    host: nginx
    port: 30920
    protocol: http
  flow-stream-data-pipeline:
    host: nginx
    port: 13012
    protocol: http
  hydra-admin:
    host: nginx
    port: 4445
    protocol: http
  index-base:
    host: mdl-index-base-svc
    port: 13013
    protocol: http
  mq:
    auth:
      mechanism: ""
      password: xxxxxx
      username: anyrobot
    connectorType: nsq
    mqHost: proton-mq-nsq-nsqd.resource
    mqLookupdHost: proton-mq-nsq-nsqlookupd.resource
    mqLookupdPort: 4161
    mqPort: 4151
    mqType: nsq
    protocol: plaintext
    tenant: default
  opensearch:
    host: opensearch-master.resource
    password: xxxxxx
    port: 9200
    protocol: http
    user: ''
  rds:
    database: kweaver
    host: mariadb-mariadb-master.resource
