project:
  language: "zh-CN"
  host: "0.0.0.0"
  port: 9000
  logger_level: 1
  name: "agent-operator-integration"
  pod_id: "POD_ID"
  machine_id: ""
  debug: false
operator:
  import_file_size_limit: 2.097152e+06
  import_operator_max_count: 10
  operator_description_length_limit: 500
mcp:
  conn_timeout: 30
  max_instances: 100
  instance_ttl: 1800
  cleanup_interval: 600
category:
  init_switch: true
proxy_module:
  default_timeout: 300
  max_timeout: 300
  max_clients: 50
  client_lifetime: 600
skill_index_build:
  enable_periodic_full_scan: false
  periodic_full_scan_interval: "168h"
  enable_task_cleanup: false
  task_retention: "720h"
oauth:
  public_host: "hydra-public"
  public_port: 4444
  public_protocol: "http"
  admin_host: "hydra-admin"
  admin_port: 4445
  admin_protocol: "http"
  admin_prefix: "/admin"
user_management:
  private_protocol: "http"
  private_host: "user-management-private"
  private_port: 30980
authorization:
  private_protocol: "http"
  private_host: "authorization-private"
  private_port: 30920
business-system-service:
  private_protocol: "http"
  private_host: "business-system-service"
  private_port: 80
db:
  conn_timeout: 30
  read_timeout: 30
  write_timeout: 30
  max_open_conns: 30
  system_id: ""
redis:
  connectType: "sentinel"
  enableSSL: false
  secretName: ""
  caName: ""
  certName: ""
  keyName: ""
  poolSize: 10
flow-automation:
  private_protocol: "http"
  private_host: "flow-automation-private"
  private_port: 8680
sandbox-control-plane:
  private_protocol: "http"
  private_host: "sandbox-control-plane"
  private_port: 8000
  template_id: ""
  session_resources:
    cpu: "1"
    memory: "512Mi"
    disk: "1Gi"
    timeout: 3600
  max_sessions: 3
  active_sessions: 1
  max_concurrent_tasks: 100
mf-model-api:
  private_protocol: "http"
  private_host: "mf-model-api"
  private_port: 9898
mf-model-manager:
  private_protocol: "http"
  private_host: "mf-model-manager"
  private_port: 9898
ai_generation_config:
  python_function_generator_prompt_id: ""
  metadata_param_generator_prompt_id: ""
  llm:
    model: ""
    max_tokens: 2048
    temperature: 0.2
    top_k: 40
    top_p: 0.95
    frequency_penalty: 0
    presence_penalty: 0
oss-gateway-backend:
  private_protocol: "http"
  private_host: "oss-gateway-backend"
  private_port: 8080
  storage_id: ""
  internal_request: false
  expires: 3600
vega-backend:
  private_protocol: "http"
  private_host: "vega-backend"
  private_port: 13014
