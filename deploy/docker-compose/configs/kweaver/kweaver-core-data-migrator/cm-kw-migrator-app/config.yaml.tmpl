# KWeaver data migrator --config /app/config.yaml (from .env via setup.sh)
namespace: kweaver
replicaCount: 1
mode: Community
env:
  language: en_US.UTF-8
  timezone: Asia/Shanghai
image:
  registry: __IMAGE_REGISTRY__
auth:
  enabled: false
businessDomain:
  enabled: false
accessAddress:
  host: __ACCESS_HOST__
  port: __ACCESS_PORT__
  scheme: http
  path: /
flowAutomation:
  s3:
    default: default
    connections:
      - name: default
        endpoint: ""
        region: us-east-1
        accessKeyID: ""
        secretAccessKey: ""
        bucketName: ""
        skipVerify: true
        disableHTTPS: false
dipStudio:
  openClaw:
    configHostPath: ''
    workspaceHostPath: ''
depServices:
  mq:
    auth:
      mechanism: ""
      username: ""
      password: ""
    mqHost: kafka
    mqLookupdHost: ""
    mqLookupdPort: 0
    mqPort: 9092
    mqType: kafka
  opensearch:
    distribution: opensearch
    host: opensearch
    user: ""
    password: ""
    port: 9200
    protocol: http
    version: ""
  mongodb:
    source_type: internal
    host: localhost
    port: 28000
    user: admin
    password: ""
    replicaSet: rs0
    options:
      authSource: admin
  rds:
    admin_key: ''
    host: mariadb
    hostRead: mariadb
    port: 3306
    portRead: 3306
    source_type: internal
    type: MariaDB
    user: __MARIADB_USER__
    password: __MARIADB_PASSWORD__
    database: __MARIADB_DATABASE__
  redis:
    connectInfo:
      host: redis
      port: 6379
      password: ""
      sentinelHost: ""
      sentinelPort: 0
      sentinelPassword: ""
      sentinelUsername: ""
      username: default
      masterGroupName: mymaster
    connectType: standalone
    sourceType: internal
  structure-extractor:
    privateHost: 127.0.0.1
    privatePort: 8089
    outputDir: /output
    backend: vlm-http-client
    serverUrl: http://127.0.0.1:8089
    fileHost: 127.0.0.1
    filePort: 8090
  class-443:
    ingressClass: nginx
