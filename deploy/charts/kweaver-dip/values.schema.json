{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kweaver-core": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "required": ["enabled"]
    },
    "global": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "registry": { "type": "string" }
          }
        },
        "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "mode": { "type": "string" },
        "storageClass": { "type": "string" },
        "ingressClassName": { "type": "string" },
        "env": {
          "type": "object",
          "properties": {
            "language": { "type": "string" },
            "timezone": { "type": "string" }
          }
        },
        "accessAddress": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "scheme": { "type": "string", "enum": ["http", "https"] },
            "path": { "type": "string" }
          }
        },
        "depServices": { "type": "object" }
      }
    },
    "modules": {
      "type": "object",
      "properties": {
        "studio":       { "type": "object", "properties": { "enabled": { "type": "boolean" } }, "required": ["enabled"] },
        "modelfactory": { "type": "object", "properties": { "enabled": { "type": "boolean" } }, "required": ["enabled"] }
      }
    },
    "dbInit": {
      "type": "object",
      "properties": {
        "enabled":      { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag":        { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        }
      }
    }
  }
}
