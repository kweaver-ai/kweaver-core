
# 认证信息
USERNAME=test
PASSWORD=

ADMIN=admin
ADMINPASS=

# KWeaver 访问地址（从 deploy/conf/config.yaml 的 accessAddress.host 读取）
# 如需覆盖，可设置环境变量 IP_ADDRESS
IP_ADDRESS=

# 数据源配置

# 数据库类型
DS_TYPE=mysql
# 连接名称
DS_NAME=供应链业务分析
# 数据库名称
DS_DATABASE_NAME=tem
# 模式名称
DS_SCHEMA_NAME=
# 连接方式
DS_CONNECT_PROTOCOL=jdbc
# 连接地址
DS_HOST=
# 端口
DS_PORT=3306
# 用户名
DS_USERNAME=test
# 密码
DS_PASSWORD=
# 备注
DS_COMMENT=供应链业务分析
