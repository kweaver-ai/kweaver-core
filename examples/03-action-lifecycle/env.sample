# MySQL datasource — must be reachable from the kweaver platform (K8s internal or public IP).
# No local MySQL client needed: CSV files are uploaded and imported by the platform.
DB_HOST=192.168.40.105
DB_PORT=3306
# Database must exist. User needs CREATE TABLE / INSERT / SELECT rights.
DB_NAME=hd_supply
DB_USER=root
DB_PASS=changeme

# Set to 1 or true for extra diagnostics (passwords never printed).
# DEBUG=1
