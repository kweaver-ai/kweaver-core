# =============================================================================
# 06-world-cup · 共用环境变量（run.sh · run-branch-bkn.sh）；upload-data.sh 另见下方「可选备份」。
# 使用：cp env.sample .env && vim .env
# =============================================================================

# ── MySQL（平台经 kweaver 能访问）──────────────────────────────────────────────
# run.sh：脚本用 mysql 客户端连库；run-branch：仅 kweaver ds connect / import-csv。
# Local: 常见 127.0.0.1 + 有 DB_NAME 上权限的用户。
# Remote: DB_HOST 填公网或内网地址；云上请限制安全组，避免 0.0.0.0/0 暴露 3306。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=worldcup
DB_USER=root
DB_PASS=changeme

# ── 数据版本（download.sh）────────────────────────────────────────────────────
# 固定上游 commit/tag/分支；默认 master。
WORLDCUP_REF=master

# ── run.sh：已有 Agent 对话 ───────────────────────────────────────────────────
# 留空则取 kweaver agent list 第一个。
AGENT_ID=

# Set DEBUG=1 to print API request/response bodies (passwords are still redacted).
# DEBUG=1

# ── MySQL · import-csv 行宽（Error 1118）───────────────────────────────────────
# CLI 对每列用 VARCHAR(512)；matches / team_appearances 列数多则超单行上限。
# 默认 1：`run.sh` / `run-branch-bkn.sh` 会在灌库前删去可经其它表联接的冗余文字列。
# 若需上游完整 CSV 列且你能改 DDL/自建表，可设 0。
# SLIM_WIDE_CSV_FOR_MYSQL=0

# ── 可选：仅当你单独运行 ./upload-data.sh 备份 CSV（rsync，不写入 MySQL）────────
# ./run-branch-bkn.sh 不调用该脚本；灌库一律由 kweaver ds import-csv 完成。
# REMOTE_USER=ubuntu
# REMOTE_HOST=your.server.ip.or.hostname
# REMOTE_DIR=/home/ubuntu/worldcup-csv-data

# ── run-branch-bkn.sh：BKN 导出与推送 ─────────────────────────────────────────
KN_NAME_BRANCH=worldcup_bkn_branch
BKN_EXPORT_DIR=./bkn-export/worldcup
DO_BKN_PUSH=true
# 脚本退出时自动删除本次新建的 KN + 数据源（一般不设）
# TEARDOWN_BRANCH=1

# ── run-branch-bkn.sh：新建 Agent（留空 AGENT_LLM_ID 则跳过）──────────────────
SKIP_AGENT=false
AGENT_NAME=世界杯数据分析助手
AGENT_PROFILE=基于世界杯知识网络回答问题，可多表推理，不确定时请说明假设
# kweaver call .../llm/list 或 Studio 取 id
AGENT_LLM_ID=
# BRANCH_CHAT_QUESTION=哪位球员累计进球最多？
