# =============================================================================
# 06-world-cup · 共用环境变量（run.sh · run-branch-vega.sh · create-agent-from-kn.sh）
# upload-data.sh 另见下方「可选备份」。
# 使用：cp env.sample .env && vim .env
# =============================================================================

# ── MySQL（平台经 kweaver / Vega 能访问）───────────────────────────────────────
# run.sh：脚本用 mysql 客户端连本地库做可选检查。
# Local: 常见 127.0.0.1 + 有 DB_NAME 上权限的用户。
# Remote: DB_HOST 填公网或内网地址；云上请限制安全组，避免 0.0.0.0/0 暴露 3306。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=worldcup
DB_USER=root
DB_PASS=changeme
#
# KWeaver CLI：登录后默认用 ~/.kweaver 当前平台，无需 base-url。与 DB_HOST 无关。
# 仅在要固定指向某实例时设置：KWEAVER_BASE_URL=https://你的平台域名或 IP

# ── 数据版本（download.sh）────────────────────────────────────────────────────
# 固定上游 commit/tag/分支；默认 master。
WORLDCUP_REF=master

# ── run.sh：已有 Agent 对话 ───────────────────────────────────────────────────
# 留空则取 kweaver agent list 第一个。
AGENT_ID=

# Set DEBUG=1 to print API request/response bodies (passwords are still redacted).
# DEBUG=1

# ── MySQL · import-csv 行宽（Error 1118）───────────────────────────────────────
# CLI 对每列用 VARCHAR(512)；matches / team_appearances 列数多则超单行上限。
# 默认 1：run.sh 会在灌库前删去可经其它表联接的冗余文字列。
# 若需上游完整 CSV 列且你能改 DDL/自建表，可设 0。
# SLIM_WIDE_CSV_FOR_MYSQL=0

# ── 可选：仅当你单独运行 ./upload-data.sh 备份 CSV（rsync，不写入 MySQL）────────
# 灌库：`run.sh` 内 `create-from-csv`，或按需自行 `kweaver ds import-csv …`。
# REMOTE_USER=ubuntu
# REMOTE_HOST=your.server.ip.or.hostname
# REMOTE_DIR=/home/ubuntu/worldcup-csv-data

# ── Vega Catalog（不经 Dataview，见 WORKFLOW-BRANCH-VEGA.zh.md）──────────────
# ./run-branch-vega.sh：按 DB_* 拼 connector-config，create catalog → discover。
# ./run-vega-bkn-push.sh：拉 table Resource UUID → 渲染 worldcup-bkn-vega → validate → push → bkn build（索引进平台）。
# cp env.sample .env 填好上方 DB_* 后再设：
# VEGA_CATALOG_NAME=worldcup_mysql_vega
# 若 Vega 必须用与 DB_HOST 不同的地址（服务端网络视角）：
# VEGA_MYSQL_HOST=mysql.internal.cluster
# VEGA_MYSQL_PORT=3306
# VEGA_MYSQL_USER=
# VEGA_MYSQL_PASS=
# databases 默认为 ["$DB_NAME"]；多库时使用 JSON 数组字符串：
# VEGA_MYSQL_DATABASES='["worldcup","otherdb"]'
# VEGA_SKIP_CREATE=1               仅用已有目录：与 VEGA_CATALOG_ID 一起给 run-branch-vega.sh
# VEGA_CATALOG_ID=<uuid>           可选；已设则可省去 catalog 名称查找（run-branch-vega / run-vega-bkn-push）
# 若 create 报「目录名称已存在」(409)：可设上面的 CATALOG_ID 再跑脚本。
#
# `run-vega-bkn-push.sh` 会根据 discover 生成的 table Resource 自动填齐 `worldcup-bkn-vega/` 占位符并 `push`（无需手写 27 次 object-type create）。

# ── create-agent-from-kn.sh（独立：仅凭已推送 KN 创建/绑定 Agent）────────────
# ./create-agent-from-kn.sh   （需 AGENT_LLM_ID；KN id 默认读 worldcup-bkn-vega/network.bkn）
# 可选：WC_KN_ID=... 覆盖平台上的知识网络 id
# 可选：REUSE_AGENT_BY_NAME=true  同名则只 update KN + publish，不重复 create
# 可选：AGENT_TEMPLATE_ID=<tpl>   用平台模板生成 config（可不设 AGENT_LLM_ID，视模板而定）
# 可选：AGENT_SYSTEM_PROMPT="..."  覆盖默认系统提示
# 可选：SKIP_WRITE_ENV=1           成功后不自动改写 .env 中的 AGENT_ID
