# Backing datasource for CSV import. The script connects MySQL with these creds
# and imports all 27 World Cup CSVs as tables under the same DS.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=worldcup
DB_USER=root
DB_PASS=changeme

# Optional: pin to a specific worldcup commit/tag for reproducibility.
# Defaults to `master` if unset.
WORLDCUP_REF=master

# Optional: skip the agent chat step if no Agent is provisioned on the platform.
# When unset, the script reuses the first agent returned by `kweaver agent list`.
AGENT_ID=

# Set DEBUG=1 to print API request/response bodies (passwords are still redacted).
# DEBUG=1
